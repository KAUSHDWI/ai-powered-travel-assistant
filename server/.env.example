# ============================================
# AI-Powered Travel Lead Assistant — Server
# ============================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- MongoDB ---
# Local (docker-compose): mongodb://localhost:27017/travel-lead-assistant
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/travel-lead-assistant
MONGODB_URI=mongodb://localhost:27017/travel-lead-assistant
# --- Google Gemini AI ---
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# --- JWT Authentication ---
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=info
