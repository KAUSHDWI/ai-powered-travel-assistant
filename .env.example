# ==============================================================================
# TRAVEL LEAD ASSISTANT — MASTER CONFIGURATION TEMPLATE
# ==============================================================================

# Note: Copy variables from here to server/.env or client/.env as needed.

# ─── SERVER-SIDE VARIABLES (server/.env) ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/travel-lead-assistant

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# JWT Token Secrets (must be minimum 32 character strings)
JWT_ACCESS_SECRET=your_access_token_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logs level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# CLI Seeding Parameters (used when seeding admin records)
ADMIN_EMAIL=admin@travelassistant.com
ADMIN_PASSWORD=Admin@12345678


# ─── CLIENT-SIDE VARIABLES (client/.env) ──────────────────────────────────────
# Leave blank in development to proxy requests through Vite local servers.
# In production, set to your hosted backend url: https://api.travelassistant.com
VITE_API_URL=
